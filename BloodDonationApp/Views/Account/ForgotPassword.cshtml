@{
    ViewData["Title"] = "Forgot Password - Donora";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-md border-0" style="background-color: #FFFFFF; border: 1px solid #E8DDD5 !important; box-shadow: 0 2px 16px rgba(0,0,0,0.07) !important;">
                <div class="card-header text-center py-4" style="background-color: #7D2B2B !important; border-bottom: 2px solid #B5894A !important;">
                    <h2 class="mb-0" style="color: #F5ECD7; font-family: 'Times New Roman', serif; letter-spacing: 2px;">D O N O R A</h2>
                    <small class="text-uppercase" style="color: #B5894A; letter-spacing: 1px;">Password Recovery</small>
                </div>
                <div class="card-body p-4">
                    <h4 class="text-center mb-4" style="font-family: 'Times New Roman', serif; font-style: italic; color: #5C1A1A;">Recover Your Password</h4>
                    
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-4">
                            <label class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1px;">Registered Email Address</label>
                            <input name="email" class="form-control" type="email" placeholder="e.g. john@example.com" required />
                        </div>
                        
                        <div class="form-group mb-3">
                            <button type="submit" class="btn btn-primary w-100 py-2">Request Reset Link</button>
                        </div>
                    </form>

                    @if (TempData["ResetLink"] != null)
                    {
                        <div class="card mt-4 border-warning" style="background-color: #FFFDF6; border: 1px dashed #B5894A !important;">
                            <div class="card-body p-3">
                                <h6 class="text-warning fw-bold mb-2"><i class="bi bi-envelope-fill me-2"></i>Email Simulation Box</h6>
                                <p class="small text-muted mb-3">Since this is a development system, we have simulated sending an email containing the reset link below. Click it to reset the password:</p>
                                <div class="text-center">
                                    <a href="@TempData["ResetLink"]" class="btn btn-sm btn-outline-danger px-4">Reset Password Now</a>
                                </div>
                                <div class="mt-2 text-center">
                                    <code class="small text-break" style="font-size: 0.75rem;">@TempData["ResetLink"]</code>
                                </div>
                            </div>
                        </div>
                    }
                    
                    <div class="mt-4 text-center">
                        <div class="mt-3">
                            <a asp-action="UserLogin" class="small" style="color: #B5894A; text-decoration: none; font-weight: bold;">&larr; Back to Login</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
