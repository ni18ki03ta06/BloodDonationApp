@{
    ViewData["Title"] = "Donor Login - Donora";
}

<div class="container mt-5 animate-fade-in">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg">
                <div class="card-header text-center py-4 bg-transparent border-bottom">
                    <h2 class="mb-0 text-danger font-serif" style="letter-spacing: 2px;">DONORA</h2>
                    <small class="text-uppercase text-muted" style="letter-spacing: 1px;">Donor Portal</small>
                </div>
                <div class="card-body p-4">
                    <h4 class="text-center mb-4 font-serif text-secondary" style="font-style: italic;">Sign In to Your Dashboard</h4>
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @TempData["SuccessMessage"]
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @TempData["ErrorMessage"]
                        </div>
                    }

                    <form asp-action="UserLogin" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label class="form-label text-uppercase small fw-bold text-danger">Registered Email</label>
                            <input name="email" class="form-control" type="email" placeholder="e.g. john@example.com" required />
                        </div>
                        
                        <div class="form-group mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label class="form-label text-uppercase small fw-bold text-danger mb-0">Password</label>
                                <a asp-action="ForgotPassword" class="small fw-bold text-decoration-none text-danger">Forgot Password?</a>
                            </div>
                            <div class="input-group">
                                <input name="password" id="txtPassword" class="form-control" type="password" placeholder="••••••••" required />
                                <button class="btn btn-outline-dark" type="button" id="btnTogglePassword" style="border-left: none;">
                                    <i class="bi bi-eye-slash" id="eyeIcon"></i>
                                </button>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary w-100 py-2">Enter Portal</button>
                        </div>
                    </form>
                    
                    <div class="mt-4 text-center">
                        <p class="mb-1 text-muted small">Don't have an account?</p>
                        <a asp-controller="Donor" asp-action="Register" class="btn btn-secondary btn-sm py-1 px-3 text-uppercase">Register as Donor</a>
                        <div class="mt-3">
                            <a href="/" class="small fw-bold text-decoration-none text-muted">&larr; Back to Landing Page</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
