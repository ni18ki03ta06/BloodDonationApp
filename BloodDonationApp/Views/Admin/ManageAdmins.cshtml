@model IEnumerable<BloodDonationApp.Models.Admin>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Admins";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <h1 style="font-family: 'Times New Roman', serif;">Manage System Administrators</h1>
    <span class="badge bg-danger py-2 px-3 text-uppercase">SuperAdmin Only</span>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["SuccessMessage"]
    </div>
}

<div class="card border-0 shadow-sm p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email Address</th>
                    <th>Role</th>
                    <th>Created At</th>
                    <th>Last Login</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var admin in Model)
                {
                    <tr>
                        <td><strong>@admin.Name</strong></td>
                        <td>@admin.Email</td>
                        <td>
                            <span class="badge @(admin.Role == "SuperAdmin" ? "bg-dark" : "bg-secondary")">
                                @admin.Role
                            </span>
                        </td>
                        <td>@admin.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(admin.LastLogin?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
