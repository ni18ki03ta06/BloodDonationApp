@model BloodDonationApp.Models.Donor
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "QR Donor Verification";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="text-center mb-5">
                <h2 class="display-6 fw-bold" style="font-family: 'Times New Roman', Georgia, serif; color: #3D1212;">
                    QR Donor Verification
                </h2>
                <p class="text-muted">Real-time authentication and eligibility status lookup</p>
            </div>

            @if (Model == null)
            {
                <!-- Invalid QR Code Alert -->
                <div class="card border-0 shadow-lg text-center overflow-hidden mb-4" style="border-radius: 16px;">
                    <div class="bg-danger py-4 text-white">
                        <i class="bi bi-shield-x display-1 mb-2"></i>
                        <h3 class="fw-bold m-0 font-monospace" style="letter-spacing: 1px;">INVALID QR CODE</h3>
                    </div>
                    <div class="card-body p-5">
                        <h4 class="card-title text-danger fw-bold mb-3" style="font-family: 'Georgia', serif;">Security Alert: Token Not Found</h4>
                        <p class="card-text text-muted mb-4">
                            The scanned QR code contains a token that does not match any registered donor in the Donora database. This code may have been revoked, tampered with, or generated by an unauthorized system.
                        </p>
                        <div class="alert alert-secondary border-0 p-3 mb-4 font-monospace text-start small" style="background-color: #F8F9FA;">
                            <span class="d-block text-uppercase fw-bold text-muted mb-1" style="font-size: 0.7rem;">Scan Context Logged</span>
                            <span class="d-block text-dark"><strong>Operator:</strong> @(User.Identity?.Name ?? HttpContextAccessor.HttpContext?.Session.GetString("UserEmail") ?? "Admin")</span>
                            <span class="d-block text-dark"><strong>Timestamp:</strong> @DateTime.Now.ToString("dd-MMM-yyyy HH:mm:ss")</span>
                            <span class="d-block text-dark"><strong>IP & Browser:</strong> @(HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? "unknown")</span>
                        </div>
                        <div class="d-grid gap-2">
                            <a asp-action="ScanHistory" class="btn btn-outline-danger btn-lg text-uppercase fw-bold py-3" style="font-size: 0.85rem;">
                                <i class="bi bi-clock-history me-2"></i> View Scan History
                            </a>
                            <a asp-action="Index" class="btn btn-secondary btn-lg text-uppercase fw-bold py-3" style="font-size: 0.85rem;">
                                <i class="bi bi-house-door me-2"></i> Back to Dashboard
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Donor Found -->
                <div class="card border-0 shadow-lg overflow-hidden mb-4" style="border-radius: 16px; border: 2px solid @(Model.IsVerified ? "#28a745" : "#ffc107");">
                    
                    <!-- Header Banner -->
                    <div class="py-4 px-4 text-white text-center d-flex flex-column align-items-center justify-content-center" 
                         style="background: @(Model.IsVerified ? "linear-gradient(135deg, #1e7e34 0%, #28a745 100%)" : "linear-gradient(135deg, #d39e00 0%, #ffc107 100%)");">
                        @if (Model.IsVerified)
                        {
                            <i class="bi bi-check-circle-fill display-2 mb-2 text-white shadow-sm rounded-circle"></i>
                            <h3 class="fw-bold m-0 text-uppercase font-monospace" style="letter-spacing: 1px;">Verified Donor</h3>
                            <span class="badge bg-white text-success border border-white mt-2 py-2 px-3 text-uppercase font-monospace fw-bold" style="font-size: 0.75rem;">
                                Eligible & Active
                            </span>
                        }
                        else
                        {
                            <i class="bi bi-exclamation-triangle-fill display-2 mb-2 text-dark"></i>
                            <h3 class="fw-bold m-0 text-uppercase text-dark font-monospace" style="letter-spacing: 1px;">Pending Verification</h3>
                            <span class="badge bg-dark text-warning mt-2 py-2 px-3 text-uppercase font-monospace fw-bold" style="font-size: 0.75rem;">
                                Pending Review
                            </span>
                        }
                    </div>

                    <div class="card-body p-4">
                        
                        <!-- Profile section -->
                        <div class="d-flex align-items-center pb-4 mb-4 border-bottom">
                            <div class="me-4">
                                @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
                                {
                                    <img src="@Model.ProfilePhotoPath" class="rounded-circle border border-3 border-light shadow-sm" style="width: 90px; height: 90px; object-fit: cover;" alt="Profile Picture" />
                                }
                                else
                                {
                                    <div class="rounded-circle bg-light d-flex justify-content-center align-items-center shadow-sm" style="width: 90px; height: 90px; border: 2px solid #ddd;">
                                        <i class="bi bi-person-fill text-secondary" style="font-size: 2.5rem;"></i>
                                    </div>
                                }
                            </div>
                            <div>
                                <h4 class="fw-bold mb-1" style="font-family: 'Times New Roman', serif; color: #3D1212;">@Model.Name</h4>
                                <span class="badge bg-danger fs-6 px-3">Blood Group: @Model.BloodType</span>
                                <span class="text-muted d-block mt-1 font-monospace small" style="font-size: 0.75rem;">ID: @Model.VerificationToken</span>
                            </div>
                        </div>

                        <!-- Core Details Grid -->
                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded-3">
                                    <span class="text-uppercase text-muted d-block small font-monospace" style="font-size: 0.65rem;">Age / Gender</span>
                                    <strong class="text-dark">@Model.Age Years / @Model.Gender</strong>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded-3">
                                    <span class="text-uppercase text-muted d-block small font-monospace" style="font-size: 0.65rem;">Contact Phone</span>
                                    <strong class="text-dark">@Model.Phone</strong>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded-3">
                                    <span class="text-uppercase text-muted d-block small font-monospace" style="font-size: 0.65rem;">Location</span>
                                    <strong class="text-dark">@Model.City, @Model.State</strong>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded-3">
                                    <span class="text-uppercase text-muted d-block small font-monospace" style="font-size: 0.65rem;">Availability Status</span>
                                    @if (Model.IsAvailable)
                                    {
                                        <strong class="text-success"><i class="bi bi-circle-fill me-1 small"></i> Available</strong>
                                    }
                                    else
                                    {
                                        <strong class="text-danger"><i class="bi bi-circle-fill me-1 small"></i> Busy / Unavailable</strong>
                                    }
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded-3">
                                    <span class="text-uppercase text-muted d-block small font-monospace" style="font-size: 0.65rem;">Total Donations</span>
                                    <strong class="text-dark">@Model.TotalDonations @(Model.TotalDonations == 1 ? "Time" : "Times")</strong>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded-3">
                                    <span class="text-uppercase text-muted d-block small font-monospace" style="font-size: 0.65rem;">Last Donation Date</span>
                                    <strong class="text-dark">@(Model.LastDonationDate?.ToString("dd-MMM-yyyy") ?? "No Recorded Donation")</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Scan Metadata -->
                        <div class="alert alert-secondary border-0 p-3 mb-4 font-monospace text-start small" style="background-color: #F8F9FA;">
                            <span class="d-block text-uppercase fw-bold text-muted mb-1" style="font-size: 0.7rem;">Scan Session Details</span>
                            <span class="d-block text-dark"><strong>Operator:</strong> @(HttpContextAccessor.HttpContext?.Session.GetString("UserEmail") ?? "Admin")</span>
                            <span class="d-block text-dark"><strong>Timestamp:</strong> @DateTime.Now.ToString("dd-MMM-yyyy HH:mm:ss")</span>
                            <span class="d-block text-dark"><strong>Result:</strong> @(Model.IsVerified ? "SUCCESS - ACCESS GRANTED" : "WARNING - REVIEW PENDING")</span>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2">
                            @if (!Model.IsVerified)
                            {
                                <form asp-action="VerifyUser" asp-route-id="@Model.Id" method="post" class="d-grid m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-warning btn-lg text-uppercase fw-bold py-3" style="font-size: 0.85rem;">
                                        <i class="bi bi-patch-check me-2"></i> Verify Donor Profile Now
                                    </button>
                                </form>
                            }
                            <a asp-action="ScanHistory" class="btn btn-outline-dark btn-lg text-uppercase fw-bold py-3" style="font-size: 0.85rem;">
                                <i class="bi bi-clock-history me-2"></i> View Verification History
                            </a>
                            <a asp-action="Index" class="btn btn-secondary btn-lg text-uppercase fw-bold py-3" style="font-size: 0.85rem;">
                                <i class="bi bi-house-door me-2"></i> Back to Dashboard
                            </a>
                        </div>

                    </div>
                </div>
            }

        </div>
    </div>
</div>
