@model IEnumerable<BloodDonationApp.Models.Appointment>
@{
    Layout = "_UserLayout";
    ViewData["Title"] = "My Donation Appointments";
}

<!-- FullCalendar.js CDN dependencies -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet" />

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-3 border-bottom">
        <div>
            <h2 class="fw-bold mb-1" style="font-family: 'Times New Roman', Georgia, serif; color: #3D1212;">
                My Donation Appointments
            </h2>
            <p class="text-muted mb-0">Schedule and keep track of your blood donation appointments</p>
        </div>
        <div class="mt-3 mt-md-0">
            <a asp-action="BookAppointment" class="btn btn-gold text-uppercase fw-bold font-monospace px-4 py-3" style="font-size: 0.8rem;">
                <i class="bi bi-calendar-plus-fill me-1"></i> Book Appointment
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Calendar View (Left Column) -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
                <h5 class="fw-bold mb-4" style="font-family: 'Times New Roman', Georgia, serif; color: #3D1212;">
                    <i class="bi bi-calendar-week text-gold me-2"></i> Appointments Calendar
                </h5>
                <div id="calendar" style="min-height: 400px;"></div>
            </div>
        </div>

        <!-- Appointment Records List (Right Column) -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 16px;">
                <h5 class="fw-bold mb-4" style="font-family: 'Times New Roman', Georgia, serif; color: #3D1212;">
                    <i class="bi bi-list-check text-gold me-2"></i> Scheduling History
                </h5>
                
                <div class="table-responsive" style="max-height: 500px;">
                    @if (Model == null || !Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
                            <h6 class="text-muted fw-bold mt-3">No Appointments Found</h6>
                            <p class="text-muted small">You haven't requested any donation appointments yet.</p>
                        </div>
                    }
                    else
                    {
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light font-monospace text-uppercase" style="font-size: 0.7rem;">
                                <tr>
                                    <th>Date</th>
                                    <th>Time Slot</th>
                                    <th class="text-center">Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody style="font-size: 0.8rem;">
                                @foreach (var appt in Model)
                                {
                                    var badgeClass = "bg-warning text-dark";
                                    if (appt.Status == "Approved") badgeClass = "bg-info text-white";
                                    else if (appt.Status == "Completed") badgeClass = "bg-success text-white";
                                    else if (appt.Status == "Cancelled") badgeClass = "bg-secondary text-white";
                                    
                                    <tr>
                                        <td class="font-monospace fw-bold text-secondary">
                                            @appt.AppointmentDate.ToString("dd-MMM-yyyy")
                                        </td>
                                        <td class="small font-monospace">@appt.TimeSlot</td>
                                        <td class="text-center">
                                            <span class="badge @badgeClass rounded-pill font-monospace" style="font-size: 0.65rem;">@appt.Status</span>
                                        </td>
                                        <td class="text-end">
                                            @if (appt.Status == "Pending" || appt.Status == "Approved")
                                            {
                                                <form asp-action="CancelAppointment" asp-route-id="@appt.Id" method="post" class="d-inline"
                                                      onsubmit="return confirm('Are you sure you want to cancel this appointment?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-danger btn-sm p-1 px-2 text-uppercase font-monospace" style="font-size: 0.6rem;">
                                                        <i class="bi bi-x-circle me-1"></i> Cancel
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small font-monospace">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- FullCalendar JS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const calendarEl = document.getElementById('calendar');
            
            // Map Model to calendar events
            const events = [];
            @if (Model != null)
            {
                @foreach (var appt in Model)
                {
                    var eventColor = "#ffc107"; // Pending
                    if (appt.Status == "Approved") eventColor = "#17a2b8"; // Approved
                    else if (appt.Status == "Completed") eventColor = "#28a745"; // Completed
                    else if (appt.Status == "Cancelled") eventColor = "#6c757d"; // Cancelled
                    
                    <text>
                    events.push({
                        title: "@appt.Status: @(appt.TimeSlot?.Split(" - ")[0] ?? "")",
                        start: "@appt.AppointmentDate.ToString("yyyy-MM-dd")",
                        color: "@eventColor",
                        description: "Time: @appt.TimeSlot | Notes: @appt.Notes"
                    });
                    </text>
                }
            }

            const calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                themeSystem: 'standard',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek'
                },
                events: events,
                eventDidMount: function(info) {
                    // Initialize bootstrap tooltip if desired, or simple title hover
                    info.el.title = info.event.extendedProps.description || info.event.title;
                }
            });

            calendar.render();
        });
    </script>
}
