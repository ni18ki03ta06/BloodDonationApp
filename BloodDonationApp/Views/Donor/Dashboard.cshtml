@model BloodDonationApp.Models.Donor
@{
    Layout = "_UserLayout";
    ViewData["Title"] = "Donor Dashboard";

    // Calculate days since last donation & next eligibility
    var lastDonationText = Model.LastDonationDate?.ToString("yyyy-MM-dd") ?? "None recorded";
    int daysRemaining = 0;
    int progressPercent = 100;
    if (Model.LastDonationDate.HasValue)
    {
        var nextDate = Model.LastDonationDate.Value.AddDays(56);
        if (nextDate > DateTime.Today)
        {
            daysRemaining = (nextDate - DateTime.Today).Days;
            int daysWaited = 56 - daysRemaining;
            progressPercent = Math.Clamp((daysWaited * 100) / 56, 0, 100);
        }
    }

    // Determine milestone level dynamically using helper
    var badgeInfo = BloodDonationApp.Helpers.DonorBadgeHelper.GetBadge(Model.TotalDonations);
    var milestone = badgeInfo.Name;
}

<div class="animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h1 class="h2 mb-0">Donor Dashboard</h1>
        <span class="badge bg-danger py-2 px-3 text-uppercase font-monospace tracking-wider">Donor Portal</span>
    </div>

    <!-- Welcome Section -->
    <div class="card border-0 shadow-sm p-4 mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="h3 mb-2 font-serif">Welcome back, @Model.Name!</h2>
                
                <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
                    <span class="badge @badgeInfo.ColorClass px-3 py-2 fs-7" style="border-radius: 50px;">@badgeInfo.Name</span>
                    <span class="text-muted small">(@Model.TotalDonations @(Model.TotalDonations == 1 ? "donation" : "donations") completed)</span>
                </div>

                @if (!badgeInfo.IsMaxTier)
                {
                    <div class="mb-3" style="max-width: 450px;">
                        <div class="d-flex justify-content-between mb-1 small text-muted">
                            <span>Next Tier: <strong>@badgeInfo.NextTierName</strong></span>
                            <span>@badgeInfo.DonationsNeeded more to unlock</span>
                        </div>
                        <div class="progress" style="height: 8px; border-radius: 4px; background-color: rgba(0,0,0,0.05);">
                            <div class="progress-bar bg-danger" role="progressbar" style="width: @badgeInfo.ProgressPercentage.ToString("F0")%; transition: width 0.6s ease;" aria-valuenow="@badgeInfo.ProgressPercentage.ToString("F0")" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="mb-3 text-success small fw-bold">
                        ★ You have reached the ultimate tier! Thank you, Lifesaver Legend!
                    </div>
                }

                <p class="text-muted mb-0">Thank you for being part of the Donora community. Your contributions save lives every day.</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a asp-action="Donate" class="btn btn-primary text-uppercase px-4 py-2 shadow-sm">Toggle Availability</a>
            </div>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="row mb-4">
        <!-- Blood Type -->
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm text-center p-3 h-100 metric-card danger">
                <h6 class="text-uppercase small fw-bold text-muted mb-2">My Blood Group</h6>
                <h2 class="text-danger mb-0 font-serif font-bold">@Model.BloodType</h2>
                <small class="text-muted mt-2">Required for matching</small>
            </div>
        </div>
        
        <!-- Status -->
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm text-center p-3 h-100 metric-card @(Model.IsAvailable ? "success" : "warning")">
                <h6 class="text-uppercase small fw-bold text-muted mb-2">Donation Status</h6>
                <h2 class="mb-0 @(Model.IsAvailable ? "text-success" : "text-warning") font-serif font-bold">
                    @(Model.IsAvailable ? "Active" : "Busy")
                </h2>
                <small class="text-muted mt-2">@(Model.IsAvailable ? "Visible in search" : "Hidden in search")</small>
            </div>
        </div>

        <!-- Total Donations -->
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm text-center p-3 h-100 metric-card info">
                <h6 class="text-uppercase small fw-bold text-muted mb-2">Total Donations</h6>
                <h2 class="text-primary mb-0 font-serif font-bold">@Model.TotalDonations</h2>
                <small class="text-muted mt-2">Milestone: <strong>@milestone</strong></small>
            </div>
        </div>

        <!-- Eligibility -->
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm text-center p-3 h-100 metric-card @(daysRemaining == 0 ? "success" : "danger")">
                <h6 class="text-uppercase small fw-bold text-muted mb-2">Next Eligibility</h6>
                <div class="d-flex flex-column align-items-center justify-content-center my-2" style="position: relative; height: 100px;">
                    <svg width="90" height="90" viewBox="0 0 100 100" class="progress-ring-svg">
                        <circle class="progress-ring-track" cx="50" cy="50" r="40" fill="transparent" stroke="rgba(0,0,0,0.05)" stroke-width="8" />
                        <circle class="progress-ring-circle" cx="50" cy="50" r="40" fill="transparent" 
                                stroke="@(daysRemaining == 0 ? "#198754" : "#dc3545")" 
                                stroke-width="8"
                                stroke-dasharray="251.2"
                                stroke-dashoffset="251.2"
                                style="--target-offset: @(251.2 - (251.2 * progressPercent) / 100); transform: rotate(-90deg); transform-origin: 50% 50%;" />
                    </svg>
                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                        @if (daysRemaining == 0)
                        {
                            <span class="fw-bold text-success font-monospace" style="font-size: 1.1rem;">READY</span>
                        }
                        else
                        {
                            <span class="fw-black text-danger font-monospace fs-4">@daysRemaining</span>
                            <div class="text-muted font-monospace" style="font-size: 0.65rem; margin-top: -5px;">DAYS</div>
                        }
                    </div>
                </div>
                <small class="text-muted mt-1">Last: @lastDonationText</small>
            </div>
        </div>
    </div>

    <!-- Live Inventory Stock Heatmap -->
    <partial name="_BloodInventoryHeatmap" />

    <style>
        .progress-ring-circle {
            animation: fillProgress 1.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }
        @@keyframes fillProgress {
            to {
                stroke-dashoffset: var(--target-offset);
            }
        }
    </style>

    <div class="row">
        <!-- Quick Actions -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h3 class="h4 mb-3 border-bottom pb-2 font-serif">Quick Actions</h3>
                <div class="d-grid gap-2">
                    <a asp-action="Profile" class="btn btn-outline-dark text-start p-3 text-uppercase small font-monospace d-flex justify-content-between align-items-center">
                        <span>Edit My Profile Details</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a asp-controller="BloodRequest" asp-action="Create" class="btn btn-outline-dark text-start p-3 text-uppercase small font-monospace d-flex justify-content-between align-items-center">
                        <span>Submit a Blood Request</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a asp-action="Search" class="btn btn-outline-dark text-start p-3 text-uppercase small font-monospace d-flex justify-content-between align-items-center">
                        <span>Search Active Donors</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a asp-action="History" class="btn btn-outline-dark text-start p-3 text-uppercase small font-monospace d-flex justify-content-between align-items-center">
                        <span>View Donation Badges & History</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Donation Guidelines -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h3 class="h4 mb-3 border-bottom pb-2 font-serif">Donation Guidelines</h3>
                <ul class="text-muted small ps-3">
                    <li class="mb-3">Ensure you are well-hydrated and have had a healthy meal before donating.</li>
                    <li class="mb-3">You must weigh at least 110 lbs (50 kg) and be in good general health.</li>
                    <li class="mb-3">A minimum interval of 56 days is required between whole blood donations.</li>
                    <li class="mb-3">Bring a valid government-issued photo ID to the donation clinic.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
