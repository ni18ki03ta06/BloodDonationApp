@model BloodDonationApp.Models.Donor
@{
    Layout = "_UserLayout";
    ViewData["Title"] = "Donor Digital ID Card";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 text-center">
            <h2 class="mb-4" style="font-family: 'Times New Roman', serif;">Donor Digital ID Card</h2>
            <p class="text-muted mb-4">
                This is your official Donora digital donor card. Present the QR code to camp staff or hospital personnel for quick verification of your donor eligibility.
            </p>

            <!-- Card Container (Target for PDF download) -->
            <div id="donor-card-capture-wrapper" class="p-3 bg-light rounded shadow-sm mb-4">
                <div id="donor-card" class="position-relative overflow-hidden text-start p-4 text-white rounded-3 shadow-lg" 
                     style="background: linear-gradient(135deg, #1C1A17 0%, #3D1212 100%); border: 2px solid #D4AF37; min-height: 480px; font-family: 'Georgia', serif;">
                    
                    <!-- Decorative background accents -->
                    <div class="position-absolute" style="top: -50px; right: -50px; width: 150px; height: 150px; border-radius: 50%; background-color: rgba(212, 175, 55, 0.05); filter: blur(20px);"></div>
                    <div class="position-absolute" style="bottom: -50px; left: -50px; width: 150px; height: 150px; border-radius: 50%; background-color: rgba(220, 53, 69, 0.05); filter: blur(20px);"></div>

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center border-bottom border-secondary pb-3 mb-4">
                        <div>
                            <h4 class="mb-0 text-gold text-uppercase fw-bold font-monospace" style="letter-spacing: 2px;">DONORA</h4>
                            <small class="text-uppercase small text-muted font-monospace" style="font-size: 0.6rem;">Life Saver Network</small>
                        </div>
                        <div>
                            @if (Model.IsVerified)
                            {
                                <span class="badge bg-success py-2 px-3 text-uppercase font-monospace border border-success" style="font-size: 0.7rem;">
                                    <i class="bi bi-patch-check-fill me-1"></i> Verified Donor
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary py-2 px-3 text-uppercase font-monospace border border-secondary" style="font-size: 0.7rem;">
                                    Pending Review
                                </span>
                            }
                        </div>
                    </div>

                    <!-- Body -->
                    <div class="row">
                        <!-- Left Panel: Profile and details -->
                        <div class="col-8">
                            <div class="d-flex align-items-center mb-3">
                                <div class="position-relative me-3">
                                    @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
                                    {
                                        <img src="@Model.ProfilePhotoPath" class="rounded-circle border border-2 border-gold shadow-sm" style="width: 80px; height: 80px; object-fit: cover;" alt="Profile Picture" />
                                    }
                                    else
                                    {
                                        <div class="rounded-circle border border-2 border-gold bg-dark d-flex justify-content-center align-items-center shadow-sm" style="width: 80px; height: 80px;">
                                            <i class="bi bi-person-fill text-gold fs-1"></i>
                                        </div>
                                    }
                                </div>
                                <div>
                                    <h5 class="mb-1 fw-bold text-gold" style="font-size: 1.15rem; font-family: 'Times New Roman', serif;">@Model.Name</h5>
                                    <span class="badge bg-danger fs-6 text-uppercase px-3">@Model.BloodType</span>
                                </div>
                            </div>

                            <div class="small mt-4">
                                <div class="mb-2 text-light">
                                    <span class="text-uppercase text-muted d-block font-monospace" style="font-size: 0.6rem;">Verification ID</span>
                                    <strong class="font-monospace" style="font-size: 0.8rem; color: #E0D4C5;">@Model.VerificationToken.Substring(0, 18)...</strong>
                                </div>
                                <div class="mb-2 text-light">
                                    <span class="text-uppercase text-muted d-block font-monospace" style="font-size: 0.6rem;">Phone Number</span>
                                    <strong style="font-size: 0.85rem; color: #E0D4C5;">@Model.Phone</strong>
                                </div>
                                <div class="mb-2 text-light">
                                    <span class="text-uppercase text-muted d-block font-monospace" style="font-size: 0.6rem;">City & State</span>
                                    <strong style="font-size: 0.85rem; color: #E0D4C5;">@Model.City, @Model.State</strong>
                                </div>
                                <div class="text-light">
                                    <span class="text-uppercase text-muted d-block font-monospace" style="font-size: 0.6rem;">Total Donations</span>
                                    <strong style="font-size: 0.85rem; color: #E0D4C5;">@Model.TotalDonations @(Model.TotalDonations == 1 ? "Donation" : "Donations")</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Right Panel: QR Code -->
                        <div class="col-4 d-flex flex-column align-items-center justify-content-center text-center">
                            <div class="p-2 bg-white rounded shadow-sm mb-2" style="border: 2.5px solid #D4AF37;">
                                <img src="data:image/png;base64,@ViewBag.QrCodeBase64" style="width: 105px; height: 105px;" alt="Verification QR Code" />
                            </div>
                            <span class="text-uppercase font-monospace text-muted" style="font-size: 0.55rem; letter-spacing: 0.5px;">Verification Link</span>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="mt-4 pt-3 border-top border-secondary d-flex justify-content-between align-items-center text-muted font-monospace" style="font-size: 0.65rem;">
                        <span>Issued: @Model.CreatedAt.ToString("MMM yyyy")</span>
                        <span class="text-uppercase text-gold">Donora verified</span>
                    </div>
                </div>
            </div>

            <!-- Download Button -->
            <button id="download-pdf-btn" class="btn btn-gold w-100 py-3 text-uppercase fw-bold shadow-sm mb-4">
                <i class="bi bi-file-earmark-pdf-fill me-2"></i> Download PDF Card
            </button>
            <a asp-action="Dashboard" class="btn btn-outline-secondary w-100 text-uppercase fw-bold">Back to Dashboard</a>
        </div>
    </div>
</div>

@section Scripts {
    <!-- html2pdf.js dependency for converting HTML element to PDF on the fly -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#download-pdf-btn').click(function() {
                const element = document.getElementById('donor-card-capture-wrapper');
                
                // Configure PDF settings
                const opt = {
                    margin:       10,
                    filename:     'Donora_Donor_Card_@(Model.Name.Replace(" ", "_")).pdf',
                    image:        { type: 'jpeg', quality: 0.98 },
                    html2canvas:  { scale: 2, useCORS: true, letterRendering: true },
                    jsPDF:        { unit: 'mm', format: 'a5', orientation: 'portrait' }
                };

                // Generate and download PDF
                html2pdf().set(opt).from(element).save().then(function() {
                    console.log("PDF download complete");
                });
            });
        });
    </script>
}
