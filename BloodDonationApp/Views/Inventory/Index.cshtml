@model IEnumerable<BloodDonationApp.Models.BloodInventory>
@{
    ViewData["Title"] = "Blood Stock Inventory";

    var donorId = HttpContextAccessor.HttpContext?.Session.GetString("UserId");
    var isLoggedIn = !string.IsNullOrEmpty(donorId);

    // Stock Status Helper
    (string label, string bgBadge, string textClass, string bgLight) GetStockStatus(int units)
    {
        if (units < 5)
        {
            return ("Critical Stock", "bg-danger text-white", "text-danger", "#FFF5F5");
        }
        else if (units <= 15)
        {
            return ("Low Stock", "bg-warning text-dark", "text-warning-dark", "#FFFDF0");
        }
        else
        {
            return ("Good Standing", "bg-success text-white", "text-success", "#F4FAF6");
        }
    }
}

<style>
    .inventory-card {
        transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: 1px solid #E8DDD5;
        border-radius: 4px;
        background-color: #FFFFFF;
    }
    .inventory-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(92, 26, 26, 0.08);
        border-color: #B5894A;
    }
    .blood-type-display {
        font-family: 'Times New Roman', Times, serif;
        font-size: 3.5rem;
        font-weight: 800;
        color: #5C1A1A;
        line-height: 1;
    }
    .text-burgundy {
        color: #5C1A1A;
    }
    .text-warning-dark {
        color: #B5894A;
    }
    .card-title-serif {
        font-family: 'Times New Roman', Times, serif;
        font-weight: bold;
    }
    .btn-burgundy {
        background-color: #5C1A1A;
        color: #FFFFFF;
        border: none;
        transition: background-color 0.2s ease;
    }
    .btn-burgundy:hover {
        background-color: #441212;
        color: #FFFFFF;
    }
    .stock-highlight {
        font-size: 2.2rem;
        font-weight: 700;
        font-family: monospace;
    }
</style>

<div class="text-center py-5 mb-4 bg-light border-bottom" style="background: linear-gradient(180deg, #FBF7F0 0%, #F5EFEB 100%) !important; border-color: #E8DDD5 !important; border-radius: 4px;">
    <h1 class="display-4 text-burgundy card-title-serif mb-2">Live Blood Stock Inventory</h1>
    <p class="lead text-muted mx-auto" style="max-width: 600px;">
        Explore current blood reserves at Donora. Your timely contribution can bridge stock deficits and save lives in emergency situations.
    </p>
    <div class="d-flex justify-content-center gap-3 mt-3">
        <span class="badge bg-danger px-3 py-2"><i class="bi-exclamation-triangle-fill me-1"></i> Critical: &lt; 5 Units</span>
        <span class="badge bg-warning text-dark px-3 py-2"><i class="bi-exclamation-circle-fill me-1"></i> Low: 5 - 15 Units</span>
        <span class="badge bg-success px-3 py-2"><i class="bi-check-circle-fill me-1"></i> Good: &gt; 15 Units</span>
    </div>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        var status = GetStockStatus(item.UnitsAvailable);
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card h-100 inventory-card shadow-sm border-0" id="inventory-card-@item.Id" data-blood-type="@item.BloodType">
                <div class="card-body d-flex flex-column text-center p-4 inventory-card-body" style="background-color: @status.bgLight;">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge @status.bgBadge px-3 py-2 text-uppercase font-monospace small status-badge">@status.label</span>
                        <small class="text-muted last-updated" title="Last updated time"><i class="bi-clock-history me-1"></i>Updated</small>
                    </div>

                    <div class="my-3">
                        <div class="blood-type-display mb-1">@item.BloodType</div>
                        <div class="text-muted small text-uppercase fw-bold letter-spacing-1">Blood Type</div>
                    </div>

                    <div class="my-4 py-3 border-top border-bottom" style="border-color: rgba(92, 26, 26, 0.08) !important;">
                        <span class="stock-highlight @status.textClass stock-units">@item.UnitsAvailable</span>
                        <div class="text-muted small text-uppercase">Available Units</div>
                        <div class="units-reserved-container mt-2">
                            @if (item.UnitsReserved > 0)
                            {
                                <span class="badge bg-secondary units-reserved-badge">@item.UnitsReserved Units Reserved</span>
                            }
                        </div>
                    </div>

                    <div class="mt-auto">
                        @if (isLoggedIn)
                        {
                            <a asp-controller="Donor" asp-action="Donate" class="btn btn-burgundy w-100 py-2 text-uppercase fw-bold">
                                <i class="bi-droplet-fill me-2"></i>Donate Now
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Donor" asp-action="Register" class="btn btn-burgundy w-100 py-2 text-uppercase fw-bold">
                                <i class="bi-plus-circle-fill me-2"></i>Register to Donate
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm p-4 mt-4 bg-white" style="border: 1px solid #E8DDD5 !important;">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h4 class="text-burgundy card-title-serif mb-2">Need immediate blood units for a patient?</h4>
            <p class="text-muted mb-md-0">Create an emergency request to match with available donors and secure inventory reserved units.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a asp-controller="BloodRequest" asp-action="Create" class="btn btn-outline-dark px-4 py-2 text-uppercase fw-bold">
                <i class="bi-chat-right-text-fill me-2"></i>Request Blood
            </a>
        </div>
    </div>
</div>
