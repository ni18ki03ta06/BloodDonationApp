@model dynamic
@using System.Text.Encodings.Web
@{
    Layout = "_UserLayout";
    ViewData["Title"] = "Nearby Donor & Camp Finder";
    
    var nearbyDonors = ViewBag.NearbyDonors as List<BloodDonationApp.Controllers.NearbyDonorViewModel> ?? new List<BloodDonationApp.Controllers.NearbyDonorViewModel>();
    var nearbyCamps = ViewBag.NearbyCamps as List<BloodDonationApp.Controllers.NearbyCampViewModel> ?? new List<BloodDonationApp.Controllers.NearbyCampViewModel>();
    bool isAdmin = ViewBag.IsAdmin ?? false;
    
    var centerLat = ViewBag.CenterLat;
    var centerLng = ViewBag.CenterLng;
    var centerLabel = ViewBag.CenterLabel;
    var apiKey = ViewBag.GoogleMapsApiKey;
}

<div class="container-fluid px-4 py-3">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <div>
            <h1 style="font-family: 'Times New Roman', serif; color: #5C1A1A;" class="fw-bold m-0"><i class="bi bi-map-fill"></i> Nearby Donor & Camp Finder</h1>
            <p class="text-muted m-0 small">Locate compatible blood donors and upcoming blood donation drives in your proximity.</p>
        </div>
        <a href="@Url.Action("Dashboard", "Donor")" class="btn btn-outline-secondary btn-sm text-uppercase fw-bold shadow-sm"><i class="bi bi-arrow-left"></i> Dashboard</a>
    </div>

    <!-- Search Form Bar -->
    <div class="card border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, #FDFBF7 0%, #F5EFEB 100%); border: 1px solid #E8DDD5 !important;">
        <div class="card-body p-3">
            <form method="get" action="@Url.Action("Finder", "Map")" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label text-uppercase small fw-bold text-muted" style="letter-spacing: 0.5px;">Search Location</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-danger"><i class="bi bi-geo-alt-fill"></i></span>
                        <input type="text" name="searchTerm" class="form-control border-start-0 ps-0" placeholder="Enter city, state, or pincode..." value="@ViewBag.SearchTerm" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-uppercase small fw-bold text-muted" style="letter-spacing: 0.5px;">Filter by Blood Type</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-danger"><i class="bi bi-droplet-fill"></i></span>
                        <select name="bloodType" class="form-select border-start-0 ps-0">
                            <option value="">All Blood Types (Camps only)</option>
                            <option value="A+" selected="@(ViewBag.BloodTypeFilter == "A+")">A+</option>
                            <option value="A-" selected="@(ViewBag.BloodTypeFilter == "A-")">A-</option>
                            <option value="B+" selected="@(ViewBag.BloodTypeFilter == "B+")">B+</option>
                            <option value="B-" selected="@(ViewBag.BloodTypeFilter == "B-")">B-</option>
                            <option value="AB+" selected="@(ViewBag.BloodTypeFilter == "AB+")">AB+</option>
                            <option value="AB-" selected="@(ViewBag.BloodTypeFilter == "AB-")">AB-</option>
                            <option value="O+" selected="@(ViewBag.BloodTypeFilter == "O+")">O+</option>
                            <option value="O-" selected="@(ViewBag.BloodTypeFilter == "O-")">O-</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-danger w-100 text-uppercase fw-bold py-2 shadow-sm" style="background-color: #8B0000; border-color: #700000;">
                        <i class="bi bi-search"></i> Search Map
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Main Grid Section -->
    <div class="row g-4">
        <!-- Map Column -->
        <div class="col-xl-8 col-lg-7">
            <div class="card border-0 shadow-sm overflow-hidden h-100" style="border: 1px solid #E8DDD5 !important; min-height: 500px;">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3 border-0">
                    <h5 class="mb-0 text-uppercase fw-bold" style="letter-spacing: 1px; font-size: 0.9rem;"><i class="bi bi-globe-americas"></i> Live Proximity Map</h5>
                    <span class="badge bg-danger shadow-sm py-1 px-2" style="font-size: 0.75rem;"><i class="bi bi-compass"></i> Center: @centerLabel</span>
                </div>
                <div id="map-container" style="width: 100%; height: 550px; background-color: #e9ecef; position: relative;">
                    <div id="map-canvas" style="width: 100%; height: 100%;"></div>
                    <!-- Leaflet Fallback Alert Overlay (hidden by default) -->
                    <div id="map-fallback-badge" class="position-absolute bottom-0 start-0 m-3 px-2 py-1 bg-dark text-white rounded opacity-75 small d-none" style="z-index: 1000;">
                        <i class="bi bi-info-circle-fill text-warning"></i> OpenStreetMap Active (Offline Fallback)
                    </div>
                </div>
            </div>
        </div>

        <!-- Proximity Sidebar Column -->
        <div class="col-xl-4 col-lg-5">
            <div class="card border-0 shadow-sm h-100 d-flex flex-column" style="border: 1px solid #E8DDD5 !important;">
                <div class="card-header bg-dark text-white py-2 border-0">
                    <!-- Nav tabs for switching listings -->
                    <nav>
                        <div class="nav nav-tabs border-0" id="nav-tab" role="tablist">
                            <button class="nav-link active text-uppercase fw-bold border-0 px-3 py-2 text-white bg-transparent me-2" id="nav-donors-tab" data-bs-toggle="tab" data-bs-target="#nav-donors" type="button" role="tab" aria-controls="nav-donors" aria-selected="true" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                                <i class="bi bi-people-fill text-danger"></i> Donors (@nearbyDonors.Count)
                            </button>
                            <button class="nav-link text-uppercase fw-bold border-0 px-3 py-2 text-white bg-transparent" id="nav-camps-tab" data-bs-toggle="tab" data-bs-target="#nav-camps" type="button" role="tab" aria-controls="nav-camps" aria-selected="false" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                                <i class="bi bi-calendar-event text-warning"></i> Camps (@nearbyCamps.Count)
                            </button>
                        </div>
                    </nav>
                </div>
                
                <div class="tab-content flex-grow-1 p-3 overflow-auto" id="nav-tabContent" style="max-height: 500px;">
                    <!-- Donors Tab -->
                    <div class="tab-pane fade show active" id="nav-donors" role="tabpanel" aria-labelledby="nav-donors-tab">
                        @if (!nearbyDonors.Any())
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-people-fill fs-1 d-block mb-2 text-danger opacity-25"></i>
                                <h6 class="fw-bold">No Available Donors Found</h6>
                                <p class="small mb-0">Try clearing filters or broadening search location.</p>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3">
                                @foreach (var item in nearbyDonors)
                                {
                                    var badge = BloodDonationApp.Helpers.DonorBadgeHelper.GetBadge(item.Donor.TotalDonations);
                                    <div class="card border-light shadow-sm p-3 proximity-card" style="border-left: 4px solid #C0392B !important; cursor: pointer;" onclick="focusMarker('donor', @item.Donor.Id)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="fw-bold mb-1">@item.Donor.Name</h6>
                                                <span class="badge" style="background-color: @badge.ColorClass; font-size: 0.65rem;">@badge.Name</span>
                                                <span class="badge bg-light text-dark border ms-1" style="font-size: 0.65rem;"><i class="bi bi-clock-history"></i> @item.Donor.City</span>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge bg-danger fs-6 px-2 py-1">@item.Donor.BloodType</span>
                                                <div class="text-primary small fw-bold mt-1">@item.DistanceKm.ToString("F1") km</div>
                                            </div>
                                        </div>
                                        
                                        <!-- Contact details if administrator -->
                                        @if (isAdmin)
                                        {
                                            <div class="mt-2 pt-2 border-top small bg-light p-2 rounded">
                                                <div><i class="bi bi-telephone-fill text-muted me-1"></i> @item.Donor.Phone</div>
                                                <div><i class="bi bi-envelope-fill text-muted me-1"></i> @item.Donor.Email</div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Camps Tab -->
                    <div class="tab-pane fade" id="nav-camps" role="tabpanel" aria-labelledby="nav-camps-tab">
                        @if (!nearbyCamps.Any())
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-calendar-event fs-1 d-block mb-2 text-warning opacity-25"></i>
                                <h6 class="fw-bold">No Active Camps Found</h6>
                                <p class="small mb-0">Try clearing filters or broadening search location.</p>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3">
                                @foreach (var item in nearbyCamps)
                                {
                                    <div class="card border-light shadow-sm p-3 proximity-card" style="border-left: 4px solid #F39C12 !important; cursor: pointer;" onclick="focusMarker('camp', @item.Camp.Id)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="pe-2">
                                                <h6 class="fw-bold mb-1">@item.Camp.CampName</h6>
                                                <p class="small text-muted mb-1 mb-md-0"><i class="bi bi-hospital"></i> @item.Camp.OrganizedBy</p>
                                                <span class="badge bg-light text-dark border" style="font-size: 0.65rem;"><i class="bi bi-geo-alt"></i> @item.Camp.City</span>
                                            </div>
                                            <div class="text-end flex-shrink-0">
                                                <span class="badge bg-warning text-dark px-2 py-1 font-monospace">@item.Camp.ScheduledDate.ToString("yyyy-MM-dd")</span>
                                                <div class="text-primary small fw-bold mt-1">@item.DistanceKm.ToString("F1") km</div>
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top small">
                                            <span>Registered: <strong>@item.Camp.RegisteredCount</strong> / @item.Camp.MaxDonors</span>
                                            <form method="post" action="@Url.Action("Register", "Camp")">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="campId" value="@item.Camp.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2 text-uppercase fw-bold" style="font-size: 0.7rem;">Register</button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .proximity-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .proximity-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1) !important;
    }
    .nav-tabs .nav-link.active {
        border-bottom: 3px solid #8B0000 !important;
    }
</style>

@section Scripts {
    <script>
        // Data arrays from view models
        const mapCenter = { lat: parseFloat("@centerLat"), lng: parseFloat("@centerLng") };
        const centerLabel = "@centerLabel";

        const donors = [
            @foreach (var item in nearbyDonors)
            {
                <text>{
                    id: @item.Donor.Id,
                    name: "@Html.Raw(JavaScriptEncoder.Default.Encode(item.Donor.Name))",
                    bloodType: "@item.Donor.BloodType",
                    city: "@Html.Raw(JavaScriptEncoder.Default.Encode(item.Donor.City))",
                    lat: @(item.Donor.Latitude ?? centerLat),
                    lng: @(item.Donor.Longitude ?? centerLng),
                    distance: @item.DistanceKm,
                    badge: "@Html.Raw(JavaScriptEncoder.Default.Encode(BloodDonationApp.Helpers.DonorBadgeHelper.GetBadge(item.Donor.TotalDonations).Name))"
                },</text>
            }
        ];

        const camps = [
            @foreach (var item in nearbyCamps)
            {
                <text>{
                    id: @item.Camp.Id,
                    name: "@Html.Raw(JavaScriptEncoder.Default.Encode(item.Camp.CampName))",
                    orgBy: "@Html.Raw(JavaScriptEncoder.Default.Encode(item.Camp.OrganizedBy))",
                    city: "@Html.Raw(JavaScriptEncoder.Default.Encode(item.Camp.City))",
                    lat: @(item.Camp.Latitude ?? centerLat),
                    lng: @(item.Camp.Longitude ?? centerLng),
                    distance: @item.DistanceKm,
                    date: "@item.Camp.ScheduledDate.ToString("yyyy-MM-dd")",
                    count: @item.Camp.RegisteredCount,
                    max: @item.Camp.MaxDonors
                },</text>
            }
        ];

        let activeMap = null;
        let mapMarkers = {}; // format: { 'donor_12': markerObject, 'camp_5': markerObject }
        let mapType = "google"; // "google" or "leaflet"

        // Initialize mapping logic
        function initMap() {
            // Check if Google maps is loaded properly and not placeholder
            const isGoogleLoaded = typeof google !== "undefined" && google.maps && "@apiKey" !== "YOUR_GOOGLE_MAPS_API_KEY";

            if (isGoogleLoaded) {
                initializeGoogleMap();
            } else {
                initializeLeafletMapFallback();
            }
        }

        // Initialize Google Map
        function initializeGoogleMap() {
            mapType = "google";
            const mapOptions = {
                zoom: 12,
                center: mapCenter,
                styles: [
                    { "featureType": "water", "elementType": "geometry", "stylers": [{ "color": "#e9e9e9" }, { "lightness": 17 }] },
                    { "featureType": "landscape", "elementType": "geometry", "stylers": [{ "color": "#f5f5f5" }, { "lightness": 20 }] },
                    { "featureType": "road.highway", "elementType": "geometry.fill", "stylers": [{ "color": "#ffffff" }, { "lightness": 17 }] }
                ]
            };

            const mapCanvas = document.getElementById('map-canvas');
            activeMap = new google.maps.Map(mapCanvas, mapOptions);

            // Add center marker
            new google.maps.Marker({
                position: mapCenter,
                map: activeMap,
                title: centerLabel,
                icon: 'https://maps.google.com/mapfiles/ms/icons/blue-dot.png'
            });

            const bounds = new google.maps.LatLngBounds();
            bounds.extend(mapCenter);

            // Populate donor markers
            donors.forEach(d => {
                const pos = { lat: d.lat, lng: d.lng };
                const marker = new google.maps.Marker({
                    position: pos,
                    map: activeMap,
                    title: d.name,
                    icon: 'https://maps.google.com/mapfiles/ms/icons/red-dot.png'
                });

                bounds.extend(pos);

                const infoWindow = new google.maps.InfoWindow({
                    content: `
                        <div style="font-family: 'Times New Roman', serif; min-width: 150px;">
                            <h5 style="color: #C0392B; margin-bottom: 2px;">${d.name}</h5>
                            <span class="badge bg-danger">${d.bloodType}</span>
                            <span class="badge bg-secondary">${d.badge}</span>
                            <p class="small text-muted mt-2 mb-0">City: ${d.city}<br>Distance: ${d.distance.toFixed(1)} km</p>
                        </div>
                    `
                });

                marker.addListener('click', () => {
                    infoWindow.open(activeMap, marker);
                });

                mapMarkers[`donor_${d.id}`] = marker;
            });

            // Populate camp markers
            camps.forEach(c => {
                const pos = { lat: c.lat, lng: c.lng };
                const marker = new google.maps.Marker({
                    position: pos,
                    map: activeMap,
                    title: c.name,
                    icon: 'https://maps.google.com/mapfiles/ms/icons/yellow-dot.png'
                });

                bounds.extend(pos);

                const infoWindow = new google.maps.InfoWindow({
                    content: `
                        <div style="font-family: 'Times New Roman', serif; min-width: 180px;">
                            <h5 style="color: #E67E22; margin-bottom: 2px;">${c.name}</h5>
                            <p class="small text-muted mb-1">Organized by: ${c.orgBy}</p>
                            <span class="badge bg-warning text-dark">${c.date}</span>
                            <p class="small text-muted mt-2 mb-0">City: ${c.city}<br>Distance: ${c.distance.toFixed(1)} km</p>
                        </div>
                    `
                });

                marker.addListener('click', () => {
                    infoWindow.open(activeMap, marker);
                });

                mapMarkers[`camp_${c.id}`] = marker;
            });

            // Fit bounds if we have markers
            if (donors.length > 0 || camps.length > 0) {
                activeMap.fitBounds(bounds);
            }
        }

        // Initialize Leaflet/OSM map dynamically
        function initializeLeafletMapFallback() {
            mapType = "leaflet";
            document.getElementById('map-fallback-badge').classList.remove('d-none');

            // Load Leaflet css and js dynamically
            const link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
            document.head.appendChild(link);

            const script = document.createElement('script');
            script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
            script.onload = () => {
                const mapCanvas = document.getElementById('map-canvas');
                mapCanvas.innerHTML = ""; // Clear loader/previous canvas content

                // Create leaflet map
                activeMap = L.map(mapCanvas).setView([mapCenter.lat, mapCenter.lng], 12);

                // Add OpenStreetMap tile layer
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OpenStreetMap contributors'
                }).addTo(activeMap);

                // Custom Icons
                const blueIcon = L.icon({
                    iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-blue.png',
                    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
                    iconSize: [25, 41],
                    iconAnchor: [12, 41],
                    popupAnchor: [1, -34],
                    shadowSize: [41, 41]
                });

                const redIcon = L.icon({
                    iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
                    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
                    iconSize: [25, 41],
                    iconAnchor: [12, 41],
                    popupAnchor: [1, -34],
                    shadowSize: [41, 41]
                });

                const yellowIcon = L.icon({
                    iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-gold.png',
                    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
                    iconSize: [25, 41],
                    iconAnchor: [12, 41],
                    popupAnchor: [1, -34],
                    shadowSize: [41, 41]
                });

                // Add search center marker
                L.marker([mapCenter.lat, mapCenter.lng], { icon: blueIcon })
                    .addTo(activeMap)
                    .bindPopup(`<strong>${centerLabel}</strong>`)
                    .openPopup();

                const bounds = L.latLngBounds([mapCenter.lat, mapCenter.lng]);

                // Populate donor markers
                donors.forEach(d => {
                    const marker = L.marker([d.lat, d.lng], { icon: redIcon })
                        .addTo(activeMap)
                        .bindPopup(`
                            <div style="font-family: 'Times New Roman', serif; min-width: 150px;">
                                <h5 style="color: #C0392B; margin-bottom: 2px;">${d.name}</h5>
                                <span class="badge bg-danger text-white">${d.bloodType}</span>
                                <span class="badge bg-secondary text-white">${d.badge}</span>
                                <p class="small text-muted mt-2 mb-0">City: ${d.city}<br>Distance: ${d.distance.toFixed(1)} km</p>
                            </div>
                        `);
                    
                    bounds.extend([d.lat, d.lng]);
                    mapMarkers[`donor_${d.id}`] = marker;
                });

                // Populate camp markers
                camps.forEach(c => {
                    const marker = L.marker([c.lat, c.lng], { icon: yellowIcon })
                        .addTo(activeMap)
                        .bindPopup(`
                            <div style="font-family: 'Times New Roman', serif; min-width: 180px;">
                                <h5 style="color: #E67E22; margin-bottom: 2px;">${c.name}</h5>
                                <p class="small text-muted mb-1">Organized by: ${c.orgBy}</p>
                                <span class="badge bg-warning text-dark">${c.date}</span>
                                <p class="small text-muted mt-2 mb-0">City: ${c.city}<br>Distance: ${c.distance.toFixed(1)} km</p>
                            </div>
                        `);
                    
                    bounds.extend([c.lat, c.lng]);
                    mapMarkers[`camp_${c.id}`] = marker;
                });

                // Fit bounds dynamically
                if (donors.length > 0 || camps.length > 0) {
                    activeMap.fitBounds(bounds, { padding: [30, 30] });
                }
            };
            document.head.appendChild(script);
        }

        // Focus a map marker on clicking list item
        function focusMarker(type, id) {
            const key = `${type}_${id}`;
            const marker = mapMarkers[key];
            if (!marker || !activeMap) return;

            let lat, lng;
            if (type === 'donor') {
                const item = donors.find(d => d.id === id);
                lat = item.lat;
                lng = item.lng;
            } else {
                const item = camps.find(c => c.id === id);
                lat = item.lat;
                lng = item.lng;
            }

            if (mapType === "google") {
                activeMap.setCenter({ lat: lat, lng: lng });
                activeMap.setZoom(14);
                // Open info window by triggering click programmatically
                google.maps.event.trigger(marker, 'click');
            } else if (mapType === "leaflet") {
                activeMap.setView([lat, lng], 14);
                marker.openPopup();
            }

            // Scroll map into view for mobile devices
            document.getElementById('map-container').scrollIntoView({ behavior: 'smooth' });
        }

        // Load the map on page ready
        document.addEventListener("DOMContentLoaded", initMap);
    </script>
    
    <!-- Load Google Maps if API key is present -->
    @if (!string.IsNullOrEmpty(apiKey) && apiKey != "YOUR_GOOGLE_MAPS_API_KEY")
    {
        <script src="https://maps.googleapis.com/maps/api/js?key=@apiKey&callback=initMap" async defer></script>
    }
}
