@inject BloodDonationApp.Data.ApplicationDbContext DbContext
@{
    var emergencyCount = DbContext.BloodRequests.Count(r => r.Status == "Emergency");
    var unreadFeedbackCount = DbContext.Feedbacks.Count(f => !f.IsRead);
    var userName = HttpContextAccessor.HttpContext?.Session.GetString("UserName") ?? "Admin";
    var adminIdStr = HttpContextAccessor.HttpContext?.Session.GetString("AdminId");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Donora Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        (function () {
            const theme = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
            document.documentElement.setAttribute("data-theme", theme);
        })();
    </script>
</head>
<body data-user-id="@adminIdStr" data-user-role="Admin">
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div id="sidebar-wrapper">
            <div class="sidebar-heading text-center py-4">
                <h3 class="mb-0 text-uppercase d-flex align-items-center justify-content-center gap-2" style="letter-spacing: 1px;">
                    <i class="bi bi-heart-pulse-fill text-danger"></i> Donora
                </h3>
                <small class="text-uppercase admin-sidebar-subtitle">Admin Panel</small>
            </div>
            <div class="list-group list-group-flush sidebar-nav">
                <a asp-controller="Admin" asp-action="Index" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
                <a asp-controller="Admin" asp-action="BloodRequests" class="list-group-item list-group-item-action text-white d-flex justify-content-between align-items-center" id="navBloodRequests">
                    <span class="d-flex align-items-center gap-2">
                        <i class="bi bi-droplet-fill text-danger"></i> Blood Requests
                    </span>
                    <span class="badge bg-danger rounded-pill @(emergencyCount == 0 ? "d-none" : "")" id="badgeSidebarEmergencyCount">@emergencyCount Emergency</span>
                </a>
                <a asp-controller="Admin" asp-action="Users" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-people-fill"></i> User Management
                </a>
                <a asp-controller="Admin" asp-action="Reports" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-file-earmark-bar-graph-fill"></i> Reports
                </a>
                <a asp-controller="Admin" asp-action="Analytics" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-graph-up-arrow text-danger"></i> Demand Analytics (ML)
                </a>
                <a asp-controller="Admin" asp-action="Inventory" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-hospital-fill"></i> Blood Inventory
                </a>
                <a asp-controller="Admin" asp-action="Appointments" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-calendar-event-fill"></i> Appointments Manager
                </a>
                <a asp-controller="Map" asp-action="Finder" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-geo-alt-fill"></i> Nearby Finder (Map)
                </a>
                <a asp-controller="Admin" asp-action="Feedback" class="list-group-item list-group-item-action text-white d-flex justify-content-between align-items-center" id="navFeedback">
                    <span class="d-flex align-items-center gap-2">
                        <i class="bi bi-chat-left-text-fill"></i> Feedback
                    </span>
                    @if (unreadFeedbackCount > 0)
                    {
                        <span class="badge bg-warning text-dark rounded-pill" id="badgeUnreadFeedback">@unreadFeedbackCount</span>
                    }
                </a>
                <a asp-controller="Admin" asp-action="ManageDonors" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-person-fill-gear"></i> Manage Donors
                </a>
                @if (HttpContextAccessor.HttpContext?.Session.GetString("AdminRole") == "SuperAdmin")
                {
                    <a asp-controller="Admin" asp-action="ManageAdmins" class="list-group-item list-group-item-action text-white">
                        <i class="bi bi-shield-lock-fill"></i> Manage Admins
                    </a>
                }
                <a asp-controller="Admin" asp-action="AuditLog" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-journal-text"></i> Audit Log
                </a>
                <a asp-controller="Admin" asp-action="ScanHistory" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-qr-code-scan"></i> QR Scan History
                </a>
                <a asp-controller="Admin" asp-action="Settings" class="list-group-item list-group-item-action text-white">
                    <i class="bi bi-gear-fill"></i> Settings
                </a>
                <a asp-controller="Account" asp-action="Logout" class="list-group-item list-group-item-action text-white mt-auto bg-dark-danger">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </div>
        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100">
            <nav class="navbar navbar-expand-lg border-bottom py-3 admin-topbar">
                <div class="container-fluid px-4">
                    <button class="btn btn-secondary btn-sm me-3 admin-hamburger-btn" id="sidebarToggle" type="button" aria-label="Toggle Sidebar">
                        <i class="bi bi-list"></i>
                    </button>
                    <span class="navbar-text admin-welcome-text">
                        Welcome, <strong>@userName</strong> (<span class="admin-role-text">@(HttpContextAccessor.HttpContext?.Session.GetString("AdminRole") ?? "Admin")</span>)
                    </span>
                    <div class="ms-auto d-flex align-items-center">
                        <button class="theme-toggle-btn me-3 dark-mode-toggle" type="button" aria-label="Toggle dark mode">
                            <i class="bi bi-moon-fill"></i>
                        </button>
                        <a asp-controller="Admin" asp-action="BloodRequests" asp-route-status="Emergency" class="me-3 position-relative text-decoration-none notification-bell" id="bellAdminNotificationLink" style="color: #4A2020;">
                            <i class="bi bi-bell-fill fs-5"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger @(emergencyCount == 0 ? "d-none" : "")" style="font-size: 0.65rem;" id="badgeAdminEmergencyCount">
                                @emergencyCount
                            </span>
                        </a>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-light btn-sm text-uppercase">Logout</a>
                    </div>
                </div>
            </nav>
            <div class="container-fluid p-4">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
