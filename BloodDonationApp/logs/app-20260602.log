    SELECT "r"."Id", "r"."DonorId", "r"."RedeemedAt", "r"."RewardId", "r"."Status", "r0"."Id" AS "Id0", "r0"."AvailableQuantity", "r0"."Description", "r0"."Icon", "r0"."Name", "r0"."PointsCost"
    FROM "RedeemedRewards" AS "r"
    INNER JOIN "Rewards" AS "r0" ON "r"."RewardId" = "r0"."Id"
) AS "t1" ON "t"."Id" = "t1"."DonorId"
ORDER BY "t"."Id", "t0"."Id", "t0"."Id0", "d1"."Id", "t1"."Id"
